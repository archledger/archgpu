// Phase 8 UI + Phase 11 state feedback + auto-scroll console.
//
// Key additions in Phase 11:
//  - TweakRow grows `applied` and `incompatible` properties. When a tweak is already
//    Applied, the Switch is disabled and a green "✓ Applied" badge appears in-row. When
//    it is Incompatible (e.g. NVIDIA tweak on non-NVIDIA host), the Switch is disabled
//    and an "unsupported" label appears instead.
//  - Hardware card shows the detected BootloaderType (GRUB / systemd-boot / Limine / UKI).
//  - Console is now a ScrollView wrapping a monospace Text (not TextEdit). A public
//    `scroll-console-to-end()` function, deferred through a Timer to give Slint's layout
//    a frame to measure the new viewport-height, snaps viewport-y to the bottom — but
//    only if the user is already near the bottom OR at the very top (initial state). If
//    the user has scrolled UP into the history, we respect that and don't snap.

import {
    Button,
    HorizontalBox,
    ScrollView,
    Switch,
    VerticalBox,
} from "std-widgets.slint";

// ── Reusable card container ──────────────────────────────────────────────────────────────────
component Card inherits Rectangle {
    in property <color> fill: #242424;
    background: fill;
    border-radius: 12px;

    VerticalLayout {
        padding: 20px;
        spacing: 12px;
        @children
    }
}

// ── Hero primary action button (GNOME Blue) ──────────────────────────────────────────────────
component HeroButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked();

    height: 48px;
    border-radius: 10px;
    background: !root.enabled
        ? #2A4A74
        : (ta.pressed ? #2D6EC2 : (ta.has-hover ? #4794F0 : #3584E4));
    animate background { duration: 140ms; easing: ease-in-out; }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
        mouse-cursor: root.enabled ? pointer : default;
    }

    HorizontalLayout {
        alignment: center;
        padding: 14px;
        Text {
            text: root.text;
            color: root.enabled ? #FFFFFF : #B8C7DC;
            font-size: 15px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }
}

// ── Secondary button (dark filled, optional primary tint) ────────────────────────────────────
component SecondaryButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <bool> primary: false;
    callback clicked();

    height: 38px;
    border-radius: 8px;
    background: !root.enabled
        ? #2A2A2A
        : root.primary
            ? (sta.pressed ? #2D6EC2 : (sta.has-hover ? #4794F0 : #3584E4))
            : (sta.pressed ? #3A3A3A : (sta.has-hover ? #333333 : #2F2F2F));
    animate background { duration: 120ms; }

    sta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
        mouse-cursor: root.enabled ? pointer : default;
    }

    HorizontalLayout {
        alignment: center;
        padding-left: 14px;
        padding-right: 14px;
        padding-top: 8px;
        padding-bottom: 8px;
        Text {
            text: root.text;
            color: root.enabled ? #FFFFFF : #808080;
            font-size: 13px;
            font-weight: 600;
            vertical-alignment: center;
        }
    }
}

// ── Small status badge ──────────────────────────────────────────────────────────────────────
component StateBadge inherits Rectangle {
    in property <string> text;
    in property <color> fill;
    in property <color> text-color: #0A0A0A;
    background: root.fill;
    border-radius: 6px;
    height: 22px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        alignment: center;
        Text {
            text: root.text;
            color: root.text-color;
            font-size: 10px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }
}

// ── Tab button: libadwaita-style pill with accent when active ──────────────────────────────
// Used by the tab strip under the hero to switch between Overview / NVIDIA / AMD / Intel.
// Active tab gets the GNOME Blue accent; inactive tabs are muted dark.
component TabButton inherits Rectangle {
    in property <string> text;
    in property <bool> active: false;
    in property <bool> enabled: true;
    callback clicked();

    height: 36px;
    border-radius: 8px;
    background: !root.enabled
        ? #252525
        : (root.active
            ? #3584E4
            : (tb.pressed ? #3A3A3A : (tb.has-hover ? #333333 : #262626)));
    animate background { duration: 120ms; easing: ease-in-out; }

    tb := TouchArea {
        enabled: root.enabled && !root.active;
        clicked => { root.clicked(); }
        mouse-cursor: root.enabled && !root.active ? pointer : default;
    }

    HorizontalLayout {
        alignment: center;
        padding-left: 16px;
        padding-right: 16px;
        Text {
            text: root.text;
            color: root.enabled
                ? (root.active ? #FFFFFF : #C8C8C8)
                : #6A6A6A;
            font-size: 13px;
            font-weight: root.active ? 700 : 600;
            vertical-alignment: center;
        }
    }
}

// ── Tweak row: bold title + gray subtitle on the left, Switch (or status badge) on right ────
component TweakRow inherits HorizontalLayout {
    in property <string> title;
    in property <string> subtitle;
    in-out property <bool> checked;
    in property <bool> enabled: true;

    // Phase 11/17 state flags — exclusive, but nothing enforces that in Slint; `applied`
    // wins rendering priority, then `pending_reboot`, then `incompatible`. Logic in
    // gui.rs guarantees only one is true at a time.
    in property <bool> applied: false;
    in property <bool> pending_reboot: false;
    in property <bool> incompatible: false;

    spacing: 16px;
    alignment: stretch;

    VerticalLayout {
        horizontal-stretch: 1;
        spacing: 3px;
        alignment: center;

        Text {
            text: root.title;
            color: (root.enabled && !root.incompatible) ? #FFFFFF : #8A8A8A;
            font-size: 14px;
            font-weight: 700;
            wrap: word-wrap;
        }
        Text {
            text: root.incompatible
                ? "Unsupported on this host."
                : (root.applied
                    ? "Running in the live kernel — nothing to do."
                    : (root.pending_reboot
                        ? "Config written. Reboot to make the running kernel adopt it."
                        : root.subtitle));
            color: root.incompatible
                ? #E8944B
                : (root.pending_reboot ? #E8C474 : #A0A0A0);
            font-size: 11px;
            wrap: word-wrap;
        }
    }

    VerticalLayout {
        alignment: center;
        spacing: 4px;

        // Active → green badge (switch disabled)
        if root.applied : StateBadge {
            text: "✓ Active";
            fill: #2E5C3A;
            text-color: #C8F5D4;
        }
        // PendingReboot → yellow badge (switch disabled); user needs to reboot to activate.
        if !root.applied && root.pending_reboot : StateBadge {
            text: "⟳ Reboot";
            fill: #6A5020;
            text-color: #F5DFB8;
        }
        // Incompatible → orange badge (switch disabled)
        if !root.applied && !root.pending_reboot && root.incompatible : StateBadge {
            text: "Unsupported";
            fill: #5C412E;
            text-color: #F5D4BB;
        }
        // Normal → Switch
        if !root.applied && !root.pending_reboot && !root.incompatible : Switch {
            checked <=> root.checked;
            enabled: root.enabled;
        }
    }
}

// ── Main window ─────────────────────────────────────────────────────────────────────────────
export component MainWindow inherits Window {
    title: "ArchGPU";
    background: #1E1E1E;
    default-font-family: "Inter";
    preferred-width: 820px;
    preferred-height: 820px;
    min-width: 640px;
    min-height: 580px;

    // ── Selection state (toggles) ───────────────────────────────────────────────────────────
    in-out property <bool> opt-wayland: false;
    in-out property <bool> opt-bootloader: false;
    in-out property <bool> opt-power: false;
    in-out property <bool> opt-gaming: false;
    in-out property <bool> opt-repair: false;
    in-out property <bool> opt-dry-run: true;
    in-out property <bool> opt-assume-yes: true;

    // ── Phase 11/17 per-tweak state flags (filled by gui::populate_detection) ──────────────
    //   *-applied         → green "✓ Active" badge (kernel confirms running)
    //   *-pending-reboot  → yellow "⟳ Reboot pending" badge (config written; kernel hasn't
    //                       adopted it yet — the user still needs to reboot so the new
    //                       cmdline takes effect). Only the bootloader tweak produces this
    //                       today; other tweaks just go Active.
    //   *-incompatible    → orange "Unsupported" badge (doesn't apply to this host)
    in-out property <bool> state-wayland-applied: false;
    in-out property <bool> state-wayland-pending-reboot: false;
    in-out property <bool> state-wayland-incompatible: false;
    in-out property <bool> state-bootloader-applied: false;
    in-out property <bool> state-bootloader-pending-reboot: false;
    in-out property <bool> state-bootloader-incompatible: false;
    in-out property <bool> state-power-applied: false;
    in-out property <bool> state-power-pending-reboot: false;
    in-out property <bool> state-power-incompatible: false;
    in-out property <bool> state-gaming-applied: false;
    in-out property <bool> state-gaming-pending-reboot: false;

    // Phase 20 + UI overhaul: self-heal scanner status, count, and per-action summaries.
    //   state-repair-applied       → green "✓ Active" badge (scanner found nothing to heal)
    //   repair-action-count        → # of RepairActions currently detected; drives the
    //                                hero status pill + Attention card visibility.
    //   repair-summaries           → one human-readable line per detected RepairAction
    //                                (sourced from RepairAction::human_summary), rendered
    //                                as bullets inside the Attention card.
    in-out property <bool> state-repair-applied: true;
    in-out property <int> repair-action-count: 0;
    in-out property <[string]> repair-summaries: [];

    // UI overhaul: computed count of toggles currently on. Drives the primary Apply
    // button's label ("Apply 3 actions") and disabled-state (disabled when 0).
    in-out property <int> selected-action-count:
        (root.opt-wayland ? 1 : 0)
        + (root.opt-bootloader ? 1 : 0)
        + (root.opt-power ? 1 : 0)
        + (root.opt-gaming ? 1 : 0)
        + (root.opt-repair ? 1 : 0);

    // ── Detection text (read from Rust) ────────────────────────────────────────────────────
    in-out property <string> chassis-text: "Detecting...";
    in-out property <string> bootloader-text: "Detecting...";
    in-out property <string> bootloader-type-text: "Detecting...";
    in-out property <string> gpus-text: "Detecting...";
    in-out property <bool> is-laptop: false;
    in-out property <bool> has-nvidia: false;
    in-out property <bool> has-amd: false;
    in-out property <bool> has-intel: false;
    in-out property <bool> has-intel-i915: false;
    in-out property <bool> is-hybrid: false;

    // Per-vendor detail lines rendered in each vendor tab's detection card. Populated
    // from GpuInventory by gui::populate_detection — e.g. "RTX 3060 (Ampere) · driver:
    // nvidia-open-dkms (Turing+)".
    in-out property <string> nvidia-detail-text: "";
    in-out property <string> nvidia-driver-recommendation: "";
    in-out property <string> amd-detail-text: "";
    in-out property <string> intel-detail-text: "";

    // Tabbed UI: which vendor page is visible. 0 = Overview, 1 = NVIDIA, 2 = AMD, 3 = Intel.
    // Tabs for undetected vendors are hidden by their respective `has-*` guards, so user
    // only sees what's relevant to their hardware.
    in-out property <int> current-tab: 0;

    // ── Run state ──────────────────────────────────────────────────────────────────────────
    in-out property <string> log-text: "";
    in-out property <bool> is-working: false;

    // ── Phase 15/16 sanitation warnings (populated by gui::populate_detection) ─────────────
    // Each entry is a single sentence describing a legacy / conflicting config detected on
    // this host (AMDVLK alongside RADV, xf86-video-intel, mesa-vdpau, /etc/X11/xorg.conf
    // cruft, WLR_NO_HARDWARE_CURSORS in user profile.d scripts, etc.). Rendered as amber
    // bullets in a dedicated banner card directly below the Hardware card so users see
    // them the moment the app opens.
    in-out property <[string]> sanitation-warnings: [];

    // ── Callbacks into Rust ────────────────────────────────────────────────────────────────
    callback apply();
    callback detect();
    callback diagnose();
    callback auto-optimize();
    // UI overhaul: dedicated one-click repair path fired by the Attention card's
    // "Run Repair Now" button. Bypasses opt-* toggles — runs ONLY the repair pass,
    // then re-polls detection so the Attention card dismisses itself.
    callback run-repair();

    // ── Console auto-scroll plumbing ───────────────────────────────────────────────────────
    // Kept as a public function for Rust to invoke belt-and-suspenders style after every
    // append_log. The main reactive behavior is on the ScrollView itself (see the `changed
    // viewport-height` handler below) — Slint emits that event AFTER the layout pass has
    // recomputed the Text's intrinsic height, so viewport-height is guaranteed current at
    // that point. Both paths assign the same target, so invoking this explicitly is safe.
    public function scroll-console-to-end() {
        console-scroll.viewport-y = min(0px, console-scroll.visible-height - console-scroll.viewport-height);
    }

    VerticalBox {
        padding: 16px;
        spacing: 12px;

        // Scrollable main content region -----------------------------------------------------
        ScrollView {
            vertical-stretch: 1;
            horizontal-stretch: 1;
            viewport-width: self.visible-width;

            VerticalLayout {
                spacing: 12px;

                // ── HERO / Header ──────────────────────────────────────────────────────────
                Card {
                    fill: #1F2A3A;

                    // Title row: product name on the left, health-status pill on the right.
                    // The pill is the at-a-glance signal — green when the repair scanner
                    // found nothing, amber with a count when it did. Users should never
                    // have to press Diagnose just to learn "is my system OK".
                    HorizontalLayout {
                        spacing: 12px;
                        alignment: stretch;

                        Text {
                            text: "ArchGPU";
                            color: #FFFFFF;
                            font-size: 26px;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                        Rectangle { horizontal-stretch: 1; background: transparent; }
                        StateBadge {
                            text: root.repair-action-count == 0
                                ? "✓ System healthy"
                                : "⚠ " + root.repair-action-count + " issue" + (root.repair-action-count == 1 ? "" : "s") + " detected";
                            fill: root.repair-action-count == 0 ? #2E5C3A : #6A2E2E;
                            text-color: root.repair-action-count == 0 ? #C8F5D4 : #F5C8C8;
                        }
                    }
                    Text {
                        text: "Detect your hardware, tune NVIDIA / Wayland / gaming, and install the right packages — safely.";
                        color: #B8C0CC;
                        font-size: 13px;
                        wrap: word-wrap;
                    }
                    Rectangle { height: 4px; background: transparent; }
                    HeroButton {
                        text: "✨  Auto-Optimize (Recommended)";
                        enabled: !root.is-working;
                        clicked => { root.auto-optimize(); }
                    }
                    Text {
                        text: "Scans your GPU, chassis, pacman.conf, and bootloader, then selects ONLY the toggles that are applicable to this host AND not yet applied.";
                        color: #8A94A6;
                        font-size: 11px;
                        wrap: word-wrap;
                    }
                }

                // ── TAB BAR ────────────────────────────────────────────────────────────────
                // Tabs for undetected vendors stay hidden so a typical Arch user sees exactly
                // the tabs that matter to their hardware. Multi-vendor hosts (hybrid / desktop
                // NVIDIA+iGPU) see all the relevant tabs.
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;

                    TabButton {
                        text: "Overview";
                        active: root.current-tab == 0;
                        enabled: !root.is-working;
                        clicked => { root.current-tab = 0; }
                    }
                    if root.has-nvidia : TabButton {
                        text: "NVIDIA";
                        active: root.current-tab == 1;
                        enabled: !root.is-working;
                        clicked => { root.current-tab = 1; }
                    }
                    if root.has-amd : TabButton {
                        text: "AMD";
                        active: root.current-tab == 2;
                        enabled: !root.is-working;
                        clicked => { root.current-tab = 2; }
                    }
                    if root.has-intel : TabButton {
                        text: "Intel";
                        active: root.current-tab == 3;
                        enabled: !root.is-working;
                        clicked => { root.current-tab = 3; }
                    }
                }

                // ── OVERVIEW TAB ───────────────────────────────────────────────────────────
                // Hardware + status signals (Attention, Sanitation) + summary. No tweak
                // toggles here — users navigate to a vendor tab to configure, or click
                // Auto-Optimize above for one-click cross-vendor recommendation.
                if root.current-tab == 0 : VerticalLayout {
                    spacing: 12px;

                    // Hardware card
                    Card {
                        Text {
                            text: "Detected hardware";
                            color: #FFFFFF;
                            font-size: 15px;
                            font-weight: 700;
                        }
                        Text {
                            text: "Chassis:  " + root.chassis-text;
                            color: #C8C8C8;
                            font-size: 13px;
                        }
                        Text {
                            text: root.gpus-text;
                            color: #A0A0A0;
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                        Text {
                            text: "Bootloader:  " + root.bootloader-type-text + "  ·  " + root.bootloader-text;
                            color: #A0A0A0;
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                        Rectangle { height: 6px; background: transparent; }
                        Text {
                            text: root.has-nvidia
                                ? (root.is-hybrid
                                    ? "● NVIDIA + integrated iGPU (hybrid / Optimus)"
                                    : "● NVIDIA dGPU present")
                                : "● No NVIDIA GPU — NVIDIA tab hidden; tune per-vendor settings on the AMD / Intel tab";
                            color: root.has-nvidia ? #7CC47C : #E8944B;
                            font-weight: 700;
                            font-size: 12px;
                        }
                    }

                    // Attention card — red-amber, only when repair scanner detected stale artifacts.
                    if root.repair-action-count > 0 : Rectangle {
                        background: #3A1F1F;
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: #9A3030;

                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;

                            HorizontalLayout {
                                spacing: 10px;
                                alignment: start;
                                Text {
                                    text: "⚠";
                                    color: #FF8E7A;
                                    font-size: 20px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: root.repair-action-count + " legacy artifact" + (root.repair-action-count == 1 ? "" : "s") + " from a previous ArchGPU version";
                                    color: #FF9B85;
                                    font-size: 15px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                            }
                            Text {
                                text: "Older versions of ArchGPU left state on this host that can misroute display on hybrid desktops or keep the NVIDIA GPU driverless. Run repair before re-applying other tweaks. Every action is backed up under /var/backups/archgpu/ and idempotent.";
                                color: #F5C4B8;
                                font-size: 12px;
                                wrap: word-wrap;
                            }
                            Rectangle { height: 2px; background: transparent; }
                            for summary in root.repair-summaries : Text {
                                text: "•  " + summary;
                                color: #F5DFD8;
                                font-size: 12px;
                                wrap: word-wrap;
                            }
                            Rectangle { height: 6px; background: transparent; }
                            HeroButton {
                                text: "🛠  Run Repair Now";
                                enabled: !root.is-working;
                                clicked => { root.run-repair(); }
                            }
                        }
                    }

                    // Sanitation — amber, only when sanitation scanner detected legacy cruft.
                    if root.sanitation-warnings.length > 0 : Rectangle {
                        background: #3C2A1A;
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: #8A5A20;

                        VerticalLayout {
                            padding: 18px;
                            spacing: 8px;
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: "⚠";
                                    color: #FFC66E;
                                    font-size: 18px;
                                    font-weight: 700;
                                }
                                Text {
                                    text: "Legacy configuration detected";
                                    color: #FFC66E;
                                    font-size: 14px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                            }
                            Text {
                                text: "These settings follow outdated tutorials and may degrade performance or break modern Wayland. Review and remediate before applying new tweaks.";
                                color: #E8D4B0;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                            for warn[i] in root.sanitation-warnings : Text {
                                text: "•  " + warn;
                                color: #F5DFB8;
                                font-size: 12px;
                                wrap: word-wrap;
                            }
                        }
                    }

                    // Summary card — tells user what Apply will do right now.
                    Card {
                        Text {
                            text: "Summary";
                            color: #FFFFFF;
                            font-size: 15px;
                            font-weight: 700;
                        }
                        Text {
                            text: root.selected-action-count == 0
                                ? "No actions selected. Open a vendor tab above to configure specific tweaks, or click Auto-Optimize for a one-click recommendation across every detected GPU."
                                : (root.opt-dry-run
                                    ? "Dry-run ready — clicking Preview below will show exactly what would happen for the " + root.selected-action-count + " selected action" + (root.selected-action-count == 1 ? "" : "s") + " without writing anything."
                                    : "Apply ready — clicking Apply below will execute " + root.selected-action-count + " action" + (root.selected-action-count == 1 ? "" : "s") + ". Every file write is backed up under /var/backups/archgpu/.");
                            color: root.selected-action-count == 0 ? #A0A0A0 : #C8E0C8;
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                    }
                }

                // ── NVIDIA TAB ─────────────────────────────────────────────────────────────
                // Everything that touches the NVIDIA driver / Wayland env / suspend tuning.
                // The cmdline toggle is shared with AMD/Intel tabs (same opt-bootloader bool)
                // — bootloader::apply composes per-vendor params into a single cmdline write.
                if root.current-tab == 1 && root.has-nvidia : VerticalLayout {
                    spacing: 12px;

                    // NVIDIA detection card (subtle green — NVIDIA brand adjacent).
                    Card {
                        fill: #1E3228;
                        Text {
                            text: "NVIDIA GPU";
                            color: #FFFFFF;
                            font-size: 15px;
                            font-weight: 700;
                        }
                        Text {
                            text: root.nvidia-detail-text;
                            color: #C8E0C8;
                            font-size: 13px;
                            wrap: word-wrap;
                        }
                        if root.nvidia-driver-recommendation != "" : Text {
                            text: "Recommended driver:  " + root.nvidia-driver-recommendation;
                            color: #A0C8A0;
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                        if root.is-hybrid && root.is-laptop : Text {
                            text: "● Hybrid laptop — PRIME render offload (prime-run) will be configured for Optimus workloads.";
                            color: #A0C8A0;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                        if root.is-hybrid && !root.is-laptop : Text {
                            text: "● Hybrid desktop — PRIME skipped. On a tower the physical display cable dictates the primary GPU; PRIME OutputClass drop-ins would misroute.";
                            color: #E8C474;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                    }

                    // NVIDIA tweaks card
                    Card {
                        Text {
                            text: "NVIDIA tweaks";
                            color: #FFFFFF;
                            font-size: 15px;
                            font-weight: 700;
                        }

                        TweakRow {
                            title: "Wayland environment + initramfs modules";
                            subtitle: "Writes the modern comment-only /etc/profile.d drop-in (no more legacy GBM_BACKEND global — that breaks hybrid PRIME), adds nvidia / nvidia_modeset / nvidia_uvm / nvidia_drm to initramfs via MODULES+=() (never touches HOOKS — that would break simpledrm consoles), and drops a PRIME Xorg OutputClass on hybrid LAPTOPS only.";
                            checked <=> root.opt-wayland;
                            enabled: !root.is-working;
                            applied: root.state-wayland-applied;
                            pending_reboot: root.state-wayland-pending-reboot;
                            incompatible: root.state-wayland-incompatible;
                        }

                        Rectangle { height: 1px; background: #333333; }

                        TweakRow {
                            title: "Kernel command line — NVIDIA params";
                            subtitle: "Verifies nvidia_drm.modeset=1 and fbdev=1 (native Wayland + hi-res TTY). Note: Modern nvidia-utils (560+) handle this via modprobe automatically; bootloader injection is only used as a fallback. Writes to the detected bootloader (GRUB / systemd-boot / Limine / UKI) when needed and regenerates. Reports Active only when the running kernel confirms via /sys/module/nvidia_drm/parameters/.";
                            checked <=> root.opt-bootloader;
                            enabled: !root.is-working;
                            applied: root.state-bootloader-applied;
                            pending_reboot: root.state-bootloader-pending-reboot;
                            incompatible: root.state-bootloader-incompatible;
                        }

                        Rectangle { height: 1px; background: #333333; }

                        TweakRow {
                            title: root.is-laptop
                                ? "Suspend/hibernate + hybrid power tweaks  ·  laptop"
                                : "Suspend/hibernate + modprobe tweaks";
                            subtitle: "Enables nvidia-suspend / nvidia-hibernate / nvidia-resume systemd units. Writes modprobe drop-in: NVreg_UseKernelSuspendNotifiers=1 (required everywhere for Wayland wake), NVreg_PreserveVideoMemoryAllocations=1 (prevents black screen on resume — companion to nvidia-suspend.service), NVreg_DynamicPowerManagement=0x02 (laptops only). Blacklists nouveau to prevent module conflicts.";
                            checked <=> root.opt-power;
                            enabled: !root.is-working;
                            applied: root.state-power-applied;
                            pending_reboot: root.state-power-pending-reboot;
                            incompatible: root.state-power-incompatible;
                        }

                        Rectangle { height: 1px; background: #333333; }

                        TweakRow {
                            title: "NVIDIA gaming stack";
                            subtitle: "Installs nvidia-utils + lib32-nvidia-utils + nvidia-settings + libva-nvidia-driver (VA-API). Driver variant picked from GPU architecture: nvidia-open-dkms (Turing+), nvidia-dkms (Pascal/Volta), or AUR legacy (nvidia-470xx-dkms / nvidia-390xx-dkms) bootstrapped via yay. Kernel headers for every installed kernel auto-queued so DKMS never silently fails.";
                            checked <=> root.opt-gaming;
                            enabled: !root.is-working;
                            applied: root.state-gaming-applied;
                            pending_reboot: root.state-gaming-pending-reboot;
                            incompatible: false;
                        }
                    }
                }

                // ── AMD TAB ────────────────────────────────────────────────────────────────
                // amdgpu cmdline tuning + RADV/libva-mesa gaming stack. No Wayland/Power
                // rows — AMD works out of the box with Mesa + kernel modesetting, nothing
                // for this tool to configure on that axis.
                if root.current-tab == 2 && root.has-amd : VerticalLayout {
                    spacing: 12px;

                    Card {
                        fill: #322020;
                        Text {
                            text: "AMD GPU";
                            color: #FFFFFF;
                            font-size: 15px;
                            font-weight: 700;
                        }
                        Text {
                            text: root.amd-detail-text;
                            color: #E0C8C8;
                            font-size: 13px;
                            wrap: word-wrap;
                        }
                        Text {
                            text: "AMD hardware works out of the box with Mesa + amdgpu — no driver install needed, no suspend tweaks, no Wayland env vars. This tab covers the two things this tool CAN usefully do: unlock power-feature bits via cmdline, and install the Vulkan + VA-API userspace stack.";
                            color: #C8A0A0;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                    }

                    Card {
                        Text {
                            text: "AMD tweaks";
                            color: #FFFFFF;
                            font-size: 15px;
                            font-weight: 700;
                        }

                        TweakRow {
                            title: "Kernel command line — AMD params";
                            subtitle: "Adds amdgpu.ppfeaturemask=0xffffffff — unlocks CoreCtrl, MorePowerTool, and all clock/voltage registers for overclocking/undervolting tools. Writes to the detected bootloader (GRUB / systemd-boot / Limine / UKI) and regenerates. Reports Active only when /sys/module/amdgpu/parameters/ppfeaturemask confirms.";
                            checked <=> root.opt-bootloader;
                            enabled: !root.is-working;
                            applied: root.state-bootloader-applied;
                            pending_reboot: root.state-bootloader-pending-reboot;
                            incompatible: root.state-bootloader-incompatible;
                        }

                        Rectangle { height: 1px; background: #333333; }

                        TweakRow {
                            title: "AMD gaming stack";
                            subtitle: "Installs vulkan-radeon + lib32-vulkan-radeon (RADV — Mesa's Vulkan driver, consistently faster than AMD's AMDVLK in Proton/Steam benchmarks) and libva-mesa-driver + lib32-libva-mesa-driver (VA-API; mesa-vdpau was removed in Mesa 25 — this is the successor). Plus gamemode / mangohud and the [multilib] + vm.max_map_count system-wide tuning.";
                            checked <=> root.opt-gaming;
                            enabled: !root.is-working;
                            applied: root.state-gaming-applied;
                            pending_reboot: root.state-gaming-pending-reboot;
                            incompatible: false;
                        }
                    }
                }

                // ── INTEL TAB ──────────────────────────────────────────────────────────────
                // i915/xe cmdline + vulkan-intel/intel-media gaming stack. The cmdline
                // toggle is only meaningful for i915 hosts — xe handles GuC/HuC natively, so
                // on a pure-xe host the cmdline tweak is a no-op (bootloader::required_
                // kernel_params returns empty for Intel xe).
                if root.current-tab == 3 && root.has-intel : VerticalLayout {
                    spacing: 12px;

                    Card {
                        fill: #1E2838;
                        Text {
                            text: "Intel GPU";
                            color: #FFFFFF;
                            font-size: 15px;
                            font-weight: 700;
                        }
                        Text {
                            text: root.intel-detail-text;
                            color: #C8D4E0;
                            font-size: 13px;
                            wrap: word-wrap;
                        }
                        if root.has-intel-i915 : Text {
                            text: "● i915 driver — GuC/HuC needs explicit enable via i915.enable_guc=3.";
                            color: #A0B8D4;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                        if !root.has-intel-i915 : Text {
                            text: "● xe driver — GuC/HuC handled natively. No kernel cmdline tweaks needed.";
                            color: #A0B8D4;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                    }

                    Card {
                        Text {
                            text: "Intel tweaks";
                            color: #FFFFFF;
                            font-size: 15px;
                            font-weight: 700;
                        }

                        if root.has-intel-i915 : TweakRow {
                            title: "Kernel command line — Intel i915 params";
                            subtitle: "Adds i915.enable_guc=3 — turns on GuC submission + HuC firmware loading. Required for hardware-accelerated video decode on Gen8+ iGPUs. Reports Active only when /sys/module/i915/parameters/enable_guc confirms.";
                            checked <=> root.opt-bootloader;
                            enabled: !root.is-working;
                            applied: root.state-bootloader-applied;
                            pending_reboot: root.state-bootloader-pending-reboot;
                            incompatible: root.state-bootloader-incompatible;
                        }

                        if root.has-intel-i915 : Rectangle { height: 1px; background: #333333; }

                        TweakRow {
                            title: "Intel gaming stack";
                            subtitle: "Installs vulkan-intel + lib32-vulkan-intel (Mesa's Vulkan driver) and intel-media-driver (iHD — the modern Gen8+ VA-API backend; Gen4-7 hosts needing legacy i965 should install libva-intel-driver manually). Plus gamemode / mangohud and the [multilib] + vm.max_map_count system-wide tuning.";
                            checked <=> root.opt-gaming;
                            enabled: !root.is-working;
                            applied: root.state-gaming-applied;
                            pending_reboot: root.state-gaming-pending-reboot;
                            incompatible: false;
                        }
                    }
                }

                // ── OPTIONS card (always visible — affects Apply regardless of tab) ────────
                Card {
                    Text {
                        text: "Options";
                        color: #FFFFFF;
                        font-size: 15px;
                        font-weight: 700;
                    }

                    TweakRow {
                        title: "Dry run";
                        subtitle: "Preview only — no files written, no pacman, no yay, no mkinitcpio. Safe to toggle and explore.";
                        checked <=> root.opt-dry-run;
                        enabled: !root.is-working;
                        applied: false;
                        incompatible: false;
                    }

                    Rectangle { height: 1px; background: #333333; }

                    TweakRow {
                        title: "Pass --noconfirm to pacman";
                        subtitle: "Required for gaming install from the GUI (no TTY to answer [Y/n] prompts on). yay's internal sudo is routed through SUDO_ASKPASS regardless.";
                        checked <=> root.opt-assume-yes;
                        enabled: !root.is-working;
                        applied: false;
                        incompatible: false;
                    }
                }

                // ── ACTION ROW ─────────────────────────────────────────────────────────────
                HorizontalLayout {
                    spacing: 10px;
                    alignment: stretch;

                    SecondaryButton {
                        text: "Refresh detection";
                        enabled: !root.is-working;
                        clicked => { root.detect(); }
                    }
                    SecondaryButton {
                        text: "Diagnose";
                        enabled: !root.is-working;
                        clicked => { root.diagnose(); }
                    }
                    Rectangle { horizontal-stretch: 1; background: transparent; }
                    SecondaryButton {
                        // Button label reflects exactly what will happen: "Preview N
                        // actions" in dry-run, "Apply N actions" otherwise. Grayed out
                        // when zero toggles are active so users don't wonder why nothing
                        // happened when they clicked it.
                        text: root.selected-action-count == 0
                            ? "No actions selected"
                            : (root.opt-dry-run
                                ? "Preview " + root.selected-action-count + " action" + (root.selected-action-count == 1 ? "" : "s")
                                : "Apply " + root.selected-action-count + " action" + (root.selected-action-count == 1 ? "" : "s"));
                        primary: root.selected-action-count > 0;
                        enabled: !root.is-working && root.selected-action-count > 0;
                        clicked => { root.apply(); }
                    }
                }

                Rectangle { height: 4px; background: transparent; }
            }
        }

        // ── CONSOLE card — OUTSIDE scroll, fills remaining vertical space ───────────────────
        Rectangle {
            background: #141414;
            border-radius: 12px;
            border-width: 1px;
            border-color: #2A2A2A;
            vertical-stretch: 1;
            horizontal-stretch: 1;
            min-height: 180px;
            clip: true;

            VerticalLayout {
                padding: 12px;
                spacing: 6px;

                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Text {
                        text: "Console";
                        color: #FFFFFF;
                        font-size: 13px;
                        font-weight: 700;
                    }
                    Text {
                        text: "live pacman / mkinitcpio / grub-mkconfig / bootctl / makepkg / yay stream";
                        color: #6A6A6A;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }

                console-scroll := ScrollView {
                    vertical-stretch: 1;
                    horizontal-stretch: 1;

                    // Reactive auto-scroll: fires every time the content height changes (a
                    // new log line was appended, or the Text rewrapped). Slint guarantees
                    // `changed` runs AFTER the layout pass, so `viewport-height` here is
                    // the NEW (post-append) content height. Unconditionally snap to the end.
                    changed viewport-height => {
                        self.viewport-y = min(0px, self.visible-height - self.viewport-height);
                    }

                    VerticalLayout {
                        Text {
                            // Dim placeholder while the log is empty so the console panel
                            // doesn't look broken on first open. Real output replaces it as
                            // soon as Rust calls append_log.
                            text: root.log-text == ""
                                ? "Output will appear here when you run Diagnose or Apply — pacman, mkinitcpio, grub-mkconfig, bootctl, makepkg, yay, dkms streams land live."
                                : root.log-text;
                            color: root.log-text == "" ? #5A5A5A : #DCDCDC;
                            font-family: root.log-text == "" ? "" : "monospace";
                            font-size: 12px;
                            wrap: word-wrap;
                            horizontal-alignment: left;
                            vertical-alignment: top;
                        }
                        // Tiny spacer so the last line isn't flush against the bottom edge.
                        Rectangle { height: 10px; background: transparent; }
                    }
                }
            }
        }
    }
}
